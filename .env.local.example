# Copy to .env.local and fill in. The Firebase values are the same ones
# the patient app uses (web config keys are not secrets — security is
# enforced via Firestore rules in the shared project).
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Kakao Maps JavaScript key. Get one free at
# https://developers.kakao.com/console/app — register a Web platform and
# add http://localhost:3000 (and your deployed origin) to the site
# domain list. Without this key the address picker still works but no
# coordinates are saved (clinics fall back to a Seoul pin in the patient app).
NEXT_PUBLIC_KAKAO_MAP_KEY=
