# Copy to .env.local and fill in. The Firebase values are the same ones
# the patient app uses (web config keys are not secrets — security is
# enforced via Firestore rules in the shared project).
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Kakao Maps JavaScript key. Get one free at
# https://developers.kakao.com/console/app — register a Web platform and
# add http://localhost:3000 (and your deployed origin) to the site
# domain list. Without this key the address picker still works but no
# coordinates are saved (clinics fall back to a Seoul pin in the patient app).
NEXT_PUBLIC_KAKAO_MAP_KEY=

# Naver Local Search (open API) credentials. Get a free key pair at
# https://developers.naver.com/apps — create an application and enable
# the "검색" (Search) API. Server-only — these MUST NOT be prefixed with
# NEXT_PUBLIC_, since requests are proxied through /api/naver/*. Without
# them the Naver tab in the address picker shows a "not configured" notice.
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# Gemini API key for automatic Korean→English clinic-name translation.
# Get a free key at https://aistudio.google.com/apikey. Server-only — the
# key is read in /api/translate (POST). When set, every clinic written
# via createClinic / createClinicsBulk gets nameEn populated automatically
# (skipped if the form already supplied one). Without it, imports still
# work — the patient app falls back to nameKr on display.
GEMINI_API_KEY=

# Admin API key — protects /api/translate and /api/naver/search from
# unauthenticated external callers. Generate any long random string:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Both vars must be set to the SAME value. ADMIN_API_KEY is server-only;
# NEXT_PUBLIC_ADMIN_API_KEY is bundled into the client to send in headers.
ADMIN_API_KEY=
NEXT_PUBLIC_ADMIN_API_KEY=

# Firebase Admin SDK — used by the /api/users/kick server route.
# Generate a service account key at:
#   Firebase Console → Project settings → Service accounts → Generate new private key
# Then extract the three fields below from the downloaded JSON.
# WARNING: These are real credentials — keep them out of git.
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
# Paste the private_key value here (with literal \n for newlines — Next.js handles the replacement):
FIREBASE_ADMIN_PRIVATE_KEY=
